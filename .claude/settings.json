{
  "permissions": {
    "allow": [
      "Read(//opt/**)",
      "Read(//usr/local/**)",
      "Read(//TGM/Apps/**)",
      "Bash(module avail *)",
      "Bash(module load *)",
      "Bash(sinfo)",
      "Bash(sinfo -s)",
      "Bash(squeue -u jaegwan97)",
      "Bash(python3)",
      "Bash(python3 *.py)",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["-c", "cd ~/materials && git pull --rebase origin main 2>&1 || echo 'git pull 실패 - 네트워크 확인 필요'"],
            "timeout": 15,
            "statusMessage": "최신 설정 동기화 중 (git pull)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["-c", "cd ~/materials && if [ -n \"$(git status --porcelain)\" ]; then git add -A && git commit -m 'Auto-sync: Claude Code session' && git push origin main 2>&1; fi"],
            "timeout": 15,
            "statusMessage": "변경사항 자동 동기화 중 (git push)..."
          }
        ]
      }
    ]
  }
}
