{
  "permissions": {
    "allow": [
      "Read(//opt/**)",
      "Read(//usr/local/**)",
      "Read(//TGM/Apps/**)",
      "Bash(module avail *)",
      "Bash(module load *)",
      "Bash(sinfo)",
      "Bash(sinfo -s)",
      "Bash(squeue -u jaegwan97)",
      "Bash(python3)",
      "Bash(python3 *.py)",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["-c", "~/materials/.claude/sync-memory.sh pull"],
            "timeout": 30,
            "statusMessage": "최신 설정 및 메모리 동기화 중 (git pull)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["-c", "~/materials/.claude/sync-memory.sh push"],
            "timeout": 30,
            "statusMessage": "메모리 및 변경사항 동기화 중 (git push)..."
          }
        ]
      }
    ]
  }
}
